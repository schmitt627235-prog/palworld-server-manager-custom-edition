{
  "name": "palworld-server-manager",
  "version": "2.1.0",
  "description": "Multi-world Palworld dedicated server manager (SteamCMD, REST API, backups, scheduler)",
  "author": "Palworld Server Manager",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "dev:next": "next dev -p 4317",
    "dev:electron": "wait-on tcp:127.0.0.1:4317 && cross-env ELECTRON_START_URL=http://localhost:4317 NODE_ENV=development electron .",
    "dev": "concurrently -k -n next,electron -c cyan,magenta \"npm:dev:next\" \"npm:dev:electron\"",
    "build:next": "next build",
    "start:next": "next start -p 4317",
    "pack": "npm run build:next && npm run prepare:standalone && electron-builder --dir",
    "dist": "npm run build:next && npm run prepare:standalone && electron-builder -wl",
    "dist:win": "npm run build:next && npm run prepare:standalone && electron-builder --win",
    "dist:linux": "npm run build:next && npm run prepare:standalone && electron-builder --linux",
    "lint": "next lint",
    "prepare:standalone": "node scripts/prepare-standalone.js"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "next": "^14.2.35",
    "node-sqlite3-wasm": "^0.8.59",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^37.2.3",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.palworld.servermanager",
    "productName": "Palworld Server Manager",
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-standalone",
        "to": "app"
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico"
    },
    "portable": {
      "artifactName": "PalworldServerManager-${version}-portable.exe"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/icon.png",
      "category": "Game"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/icon.png"
    },
    "compression": "maximum",
    "electronLanguages": [
      "en-US"
    ]
  },
  "engines": {
    "node": ">=22.5"
  }
}
